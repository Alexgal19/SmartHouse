# E2E test overrides — loaded AFTER .env.local by playwright.config.ts
# Only set values here that MUST differ between local dev and E2E tests.
# All other secrets (Firebase, passwords, etc.) are inherited from .env.local.

# Replace with the ID of a DEDICATED test Google Sheet (copy structure from prod).
# E2E tests write fake data; never point this at production data.
# SPREADSHEET_ID=YOUR_TEST_GOOGLE_SHEET_ID_HERE
